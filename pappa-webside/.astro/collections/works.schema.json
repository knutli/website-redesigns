        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "sortOrder": {
          "type": "number"
        },
        "price": {
          "type": "string",
          "default": ""
        },
        "image": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string",
          "default": ""
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "slug",
        "section",
        "image"
      ],
      "additionalProperties": false
    }
