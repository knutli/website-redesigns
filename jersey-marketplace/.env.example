# ---------------------------------------------------------------------------
# Oase — environment variables
#
# Copy this file to `.env.local` and fill in the values. See
# OUTSTANDING_SETUP.md for how to obtain each secret.
# ---------------------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# Postgres (Railway)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/oase

# ---------------------------------------------------------------------------
# Redis (Railway) — rate limits, sessions, Soketi presence
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Better Auth
# Generate:  openssl rand -base64 32
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=replace-me-with-32-bytes-of-random
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Vipps Login (seller identity verification — Norway launch)
# ---------------------------------------------------------------------------
VIPPS_ENV=test                       # "test" or "prod"
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_REDIRECT_URI=http://localhost:3000/api/auth/callback/vipps

# ---------------------------------------------------------------------------
# Stripe Connect (Express) — Vipps, Klarna, cards
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---------------------------------------------------------------------------
# Cloudflare R2 (images) + Image Resizing
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=oase-jersey-images
R2_PUBLIC_URL=https://cdn.oase.ai

# ---------------------------------------------------------------------------
# Soketi (self-hosted Pusher-compatible real-time)
# ---------------------------------------------------------------------------
SOKETI_APP_ID=oase
SOKETI_APP_KEY=
SOKETI_APP_SECRET=
SOKETI_HOST=localhost
SOKETI_PORT=6001

# Public (browser) variants — must match the server values
NEXT_PUBLIC_SOKETI_KEY=
NEXT_PUBLIC_SOKETI_HOST=localhost
NEXT_PUBLIC_SOKETI_PORT=6001

# ---------------------------------------------------------------------------
# Inngest (background jobs — auction end, digests, payouts)
# ---------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Oase <no-reply@oase.ai>"

# ---------------------------------------------------------------------------
# Monitoring / analytics (non-blocking)
# ---------------------------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=oase-logs
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
